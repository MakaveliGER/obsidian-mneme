# Optional — Mneme liest primär aus mneme.toml, Umgebungsvariablen überschreiben
# einzelne Werte. Schema: MNEME_<SECTION>__<KEY> (zwei Unterstriche zwischen
# Section und Key). Beispielwerte, bitte für dein Setup anpassen.

# --- Vault ---
# MNEME_VAULT__PATH=D:\Vault\second-brain\second-brain

# --- Embedding / GPU ---
# MNEME_EMBEDDING__DEVICE=auto            # auto | cpu | cuda
# MNEME_EMBEDDING__DTYPE=float16          # float16 | bfloat16 | float32
# MNEME_EMBEDDING__BATCH_SIZE=32

# --- Search ---
# MNEME_SEARCH__TOP_K=10
# MNEME_SEARCH__VECTOR_WEIGHT=0.6
# MNEME_SEARCH__BM25_WEIGHT=0.4

# --- Auto-Search Hook ---
# MNEME_AUTO_SEARCH__MODE=smart           # off | smart | always

# --- Debug ---
# MNEME_DEBUG=1                           # Full tracebacks statt kompakter Errors

# --- HuggingFace Cache (optional) ---
# HF_HOME=D:\Models\hf                    # Lege Modell-Cache an einen Pfad mit Platz
# HF_HUB_ENABLE_HF_TRANSFER=0             # Bei Proxy-/Firewall-Problemen deaktivieren
